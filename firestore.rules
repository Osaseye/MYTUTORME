rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && exists(path('/databases/' + database + '/documents/users/' + request.auth.uid)) && get(path('/databases/' + database + '/documents/users/' + request.auth.uid)).data.role == 'admin';
    }

    function isTeacher() {
      return request.auth != null && exists(path('/databases/' + database + '/documents/users/' + request.auth.uid)) && get(path('/databases/' + database + '/documents/users/' + request.auth.uid)).data.role == 'teacher';
    }

    // Users: only read your own profile; teachers can read student profiles; admins can read all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isTeacher());
      allow write: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );       
    }

    match /discussions/{discussionId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      
      match /replies/{replyId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }

    // EXAM PREP RULES
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Flashcards & decks are scoped to the owner
    match /flashcards/{flashcardId} {
      allow read, write: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == request.resource.data.userId ||
        isAdmin()
      );
    }

    match /flashcard_decks/{deckId} {
      allow read, write: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        request.auth.uid == request.resource.data.userId ||
        isAdmin()
      );
    }

    match /study_plan_templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    match /study_plans/{planId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        resource.data.isShared == true ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.auth.uid == request.resource.data.userId ||
        isAdmin()
      );
    }

    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /quiz_attempts/{attemptId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.studentId || isAdmin());
      allow delete: if false;
    }

    match /ai_sessions/{sessionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read, update, delete: if request.auth != null && (request.auth.uid == resource.data.studentId || isAdmin());
    }

    match /gpa_records/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /courses/{courseId} {
      allow read: if true;
      // Only teachers or admins can create courses
      allow create: if request.auth != null && (isTeacher() || isAdmin());
      // Only the course owner (teacher) or admins can update
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.teacherId || isAdmin()
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.teacherId || isAdmin()
      );
      
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if request.auth != null && (
          request.auth.uid == get(path('/databases/' + database + '/documents/courses/' + courseId)).data.teacherId || isAdmin()
        );
      }
    }

    match /smart_pool_curriculums/{docId} {
      allow read, create: if request.auth != null;
    }

    match /smart_pool_quizzes/{docId} {
      allow read, create: if request.auth != null;
    }

    // Enrollments: students can read/write their own; teachers and admins can read all
    match /enrollments/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.studentId ||
        isTeacher() ||
        isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        isTeacher() ||
        isAdmin()
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.studentId || isAdmin()
      );
    }

    // Certificates: students can read their own; admins can read/write all
    match /certificates/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.studentId ||
        isAdmin()
      );
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.studentId || isAdmin()
      );
      allow update, delete: if request.auth != null && isAdmin();
    }

    match /resources/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isTeacher() || isAdmin());
    }

    // Notifications: users can only read/update their own
    match /notifications/{docId} {
      allow read, update: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
    }

    // Support tickets: users can read/write their own; admins can read/write all
    match /support_tickets/{ticketId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();
    }

    match /assignments/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.studentId == request.auth.uid ||
        request.resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
    }

    match /mock_exams/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    // Transactions: users can read their own; admins can read all; no direct writes from clients
    match /transactions/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && isAdmin();
    }

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /platform_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
