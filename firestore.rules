rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && exists(path('/databases/' + database + '/documents/users/' + request.auth.uid)) && get(path('/databases/' + database + '/documents/users/' + request.auth.uid)).data.role == 'admin';
    }

// allow users to read and write only their own profile document, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );       
    }
    match /discussions/{discussionId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null; // Allow anyone authenticated to update (e.g., adding a reply increments repliesCount)
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      
      match /replies/{replyId} {
        allow read, create: if request.auth != null;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }

    // EXAM PREP RULES
    match /questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // Questions are immutable once generated
    }

    match /flashcards/{flashcardId} {
      allow read, write: if request.auth != null;
    }

    match /flashcard_decks/{deckId} {
      allow read, write: if request.auth != null;
    }

    match /study_plan_templates/{templateId} {
      allow read, write: if request.auth != null;
    }

    match /study_plans/{planId} {
      allow read, write: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId || isAdmin());
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /quiz_attempts/{attemptId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read, update: if request.auth != null && (request.auth.uid == resource.data.studentId || isAdmin());
      allow delete: if false;
    }

    match /ai_sessions/{sessionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.studentId;
      allow read, update, delete: if request.auth != null && (request.auth.uid == resource.data.studentId || isAdmin());
    }

    match /gpa_records/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.teacherId || isAdmin()
      );
      
      match /modules/{moduleId} {
        allow read: if true;
        allow write: if request.auth != null && (
          request.auth.uid == get(path('/databases/' + database + '/documents/courses/' + courseId)).data.teacherId || isAdmin()
        );
      }
    }

    match /smart_pool_curriculums/{docId} {
      allow read, create: if request.auth != null;
    }

    match /smart_pool_quizzes/{docId} {
      allow read, create: if request.auth != null;
    }

    match /enrollments/{docId} {
      allow read, write: if request.auth != null;
    }

    match /certificates/{docId} {
      allow read, write: if request.auth != null;
    }

    match /resources/{docId} {
      allow read, write: if request.auth != null;
    }

    match /notifications/{docId} {
      allow read, write: if request.auth != null;
    }

    match /support_tickets/{ticketId} {
      allow read, write: if request.auth != null;
    }

    match /assignments/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.studentId == request.auth.uid ||
        request.resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
    }

    match /mock_exams/{docId} {
      allow read: if request.auth != null && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid ||
        isAdmin()
      );
    }

    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }

    match /analytics/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /platform_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
