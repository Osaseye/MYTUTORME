rules_version = '2';

// Craft rules based on the exact path in your client
// This ensures that logged in users can upload profile pictures to their designated path.
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback permissive rule for prototyping - remove for production
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
