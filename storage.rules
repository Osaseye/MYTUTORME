rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: public read, owner write
    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Course thumbnails: public read, authenticated users can upload (scoped by userId)
    match /course_thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin generator uploads: only the uploader can read/write.
    // storageUploadService.ts uploads to users/{userId}/{folder}/... so rules must match that prefix.
    match /users/{userId}/admin-generator-notes/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/admin-generator-past-questions/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flashcard generator uploads: students upload source material for flashcard generation
    match /users/{userId}/flashcard-uploads/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Exam generator uploads: students upload source material for exam generation
    match /users/{userId}/exam-uploads/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    // AI tutor image uploads: students upload images/files into AI tutor chat
    match /users/{userId}/ai-tutor-images/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Theory exam uploads: students upload their own answer images
    match /users/{userId}/theory-answers/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Assignment uploads: students upload their own assignments
    match /users/{userId}/assignments/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admin course thumbnails (uploaded directly to course-thumbnails/{courseId}/...)
    // These are publicly readable so course cards can show the thumbnail.
    match /course-thumbnails/{courseId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
