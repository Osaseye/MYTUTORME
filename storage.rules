rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile pictures: public read, owner write
    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Course thumbnails: public read, authenticated users can upload (scoped by userId)
    match /course_thumbnails/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin generator uploads: only the uploader can read/write
    match /admin-generator-notes/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /admin-generator-past-questions/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Theory exam uploads: students upload their own answer images
    match /theory-answers/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
      );
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    // Assignment uploads: students upload their own assignments
    match /assignments/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
